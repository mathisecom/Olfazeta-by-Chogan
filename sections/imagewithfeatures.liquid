{%- liquid
  assign s = section.settings
  assign uid = section.id
-%}

{%- style -%}
  .iwf-{{ uid }} {
    --iwf-bg: {{ s.background_color }};
    --iwf-heading: {{ s.heading_color }};
    --iwf-text: {{ s.text_color }};
    --iwf-feature-title: {{ s.feature_title_color }};
    --iwf-pad-top: {{ s.padding_top }}px;
    --iwf-pad-bot: {{ s.padding_bottom }}px;
    --iwf-max: {{ s.container_width }}px;
    --iwf-gap: {{ s.column_gap }}px;
    --iwf-heading-size: {{ s.heading_size }}px;
    --iwf-text-size: {{ s.text_size }}px;
    --iwf-feature-title-size: {{ s.feature_title_size }}px;
    --iwf-icon-size: {{ s.icon_size }}px;

    background: var(--iwf-bg);
    padding: var(--iwf-pad-top) 20px var(--iwf-pad-bot);
    color: var(--iwf-text);
    font-family: inherit;
  }

  .iwf-{{ uid }} * { box-sizing: border-box; }

  .iwf-{{ uid }}__wrapper {
    max-width: var(--iwf-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--iwf-gap);
    align-items: center;
  }

  .iwf-{{ uid }}--reverse .iwf-{{ uid }}__wrapper {
    direction: rtl;
  }
  .iwf-{{ uid }}--reverse .iwf-{{ uid }}__media,
  .iwf-{{ uid }}--reverse .iwf-{{ uid }}__content {
    direction: ltr;
  }

  .iwf-{{ uid }}__media {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .iwf-{{ uid }}__media.is-square     { aspect-ratio: 1 / 1; }
  .iwf-{{ uid }}__media.is-portrait   { aspect-ratio: 4 / 5; }
  .iwf-{{ uid }}__media.is-landscape  { aspect-ratio: 4 / 3; }

  .iwf-{{ uid }}__media img,
  .iwf-{{ uid }}__media .iwf-{{ uid }}__placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .iwf-{{ uid }}__media.is-natural img { height: auto; aspect-ratio: auto; }

  .iwf-{{ uid }}__placeholder {
    width: 100%;
    height: 100%;
    background: #efece6;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .iwf-{{ uid }}__content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .iwf-{{ uid }}__heading {
    font-size: var(--iwf-heading-size);
    line-height: 1.2;
    color: var(--iwf-heading);
    margin: 0;
    font-weight: 400;
    font-family: inherit;
  }

  .iwf-{{ uid }}__description {
    font-size: var(--iwf-text-size);
    line-height: 1.7;
    color: var(--iwf-text);
    margin: 0;
  }
  .iwf-{{ uid }}__description p { margin: 0 0 1em; }
  .iwf-{{ uid }}__description p:last-child { margin-bottom: 0; }

  .iwf-{{ uid }}__features {
    display: flex;
    flex-direction: column;
    gap: 18px;
    margin-top: 8px;
  }

  .iwf-{{ uid }}__feature {
    display: grid;
    grid-template-columns: var(--iwf-icon-size) 1fr;
    gap: 18px;
    align-items: start;
  }

  .iwf-{{ uid }}__feature-icon {
    width: var(--iwf-icon-size);
    height: var(--iwf-icon-size);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 24px;
  }
  .iwf-{{ uid }}__feature-icon img,
  .iwf-{{ uid }}__feature-icon svg {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .iwf-{{ uid }}__feature-text {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .iwf-{{ uid }}__feature-title {
    font-size: var(--iwf-feature-title-size);
    color: var(--iwf-feature-title);
    margin: 0;
    font-weight: 600;
    line-height: 1.3;
    font-family: inherit;
  }

  .iwf-{{ uid }}__feature-description {
    font-size: var(--iwf-text-size);
    line-height: 1.6;
    color: var(--iwf-text);
    margin: 0;
  }

  /* ===== MOBILE ===== */
  @media (max-width: 749px) {
    .iwf-{{ uid }} {
      padding-top: calc(var(--iwf-pad-top) * 0.6);
      padding-bottom: calc(var(--iwf-pad-bot) * 0.6);
    }
    .iwf-{{ uid }}__wrapper,
    .iwf-{{ uid }}--reverse .iwf-{{ uid }}__wrapper {
      grid-template-columns: 1fr;
      gap: 32px;
      direction: ltr;
    }
    .iwf-{{ uid }}__heading {
      font-size: calc(var(--iwf-heading-size) * 0.75);
    }
    .iwf-{{ uid }}__feature {
      grid-template-columns: calc(var(--iwf-icon-size) * 0.85) 1fr;
      gap: 14px;
    }
    .iwf-{{ uid }}__feature-icon {
      width: calc(var(--iwf-icon-size) * 0.85);
      height: calc(var(--iwf-icon-size) * 0.85);
    }
  }

  /* ===== TABLET ===== */
  @media (min-width: 750px) and (max-width: 989px) {
    .iwf-{{ uid }}__wrapper {
      gap: calc(var(--iwf-gap) * 0.6);
    }
    .iwf-{{ uid }}__heading {
      font-size: calc(var(--iwf-heading-size) * 0.85);
    }
  }
{%- endstyle -%}

<div class="iwf-{{ uid }}{% if s.image_position == 'right' %} iwf-{{ uid }}--reverse{% endif %}">
  <div class="iwf-{{ uid }}__wrapper">

    {%- comment -%} ===== IMAGE ===== {%- endcomment -%}
    <div class="iwf-{{ uid }}__media is-{{ s.image_ratio }}">
      {%- if s.image != blank -%}
        {{ s.image | image_url: width: 1500 | image_tag:
            loading: 'lazy',
            sizes: '(max-width: 749px) 100vw, 50vw',
            widths: '375, 550, 750, 1100, 1500',
            alt: s.image.alt | default: s.heading
        }}
      {%- else -%}
        <div class="iwf-{{ uid }}__placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ===== CONTENT ===== {%- endcomment -%}
    <div class="iwf-{{ uid }}__content">

      {%- if s.heading != blank -%}
        <h2 class="iwf-{{ uid }}__heading">{{ s.heading }}</h2>
      {%- endif -%}

      {%- if s.description != blank -%}
        <div class="iwf-{{ uid }}__description">{{ s.description }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="iwf-{{ uid }}__features">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <div class="iwf-{{ uid }}__feature" {{ block.shopify_attributes }}>
                <div class="iwf-{{ uid }}__feature-icon">
                  {%- if block.settings.icon != blank -%}
                    {{ block.settings.icon | image_url: width: 100 | image_tag:
                        loading: 'lazy',
                        widths: '40, 80, 120',
                        alt: block.settings.title
                    }}
                  {%- endif -%}
                </div>
                <div class="iwf-{{ uid }}__feature-text">
                  {%- if block.settings.title != blank -%}
                    <h3 class="iwf-{{ uid }}__feature-title">{{ block.settings.title }}</h3>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <p class="iwf-{{ uid }}__feature-description">{{ block.settings.description }}</p>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image + Caractéristiques",
  "tag": "section",
  "class": "section-image-features",
  "settings": [
    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Position de l'image",
      "options": [
        { "value": "left",  "label": "Gauche" },
        { "value": "right", "label": "Droite" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Largeur maximale",
      "min": 800,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1300
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Espace entre colonnes",
      "min": 20,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 80
    },

    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image principale"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Format d'image",
      "options": [
        { "value": "square",    "label": "Carré (1:1)" },
        { "value": "portrait",  "label": "Portrait (4:5)" },
        { "value": "landscape", "label": "Paysage (4:3)" },
        { "value": "natural",   "label": "Naturel" }
      ],
      "default": "square"
    },

    {
      "type": "header",
      "content": "Titre & description"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "L'art de parfumer votre Cocon"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Taille du titre",
      "min": 20,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 36
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Chez Baiham Paris, nous souhaitons apporter notre touche de bien-être au quotidien. Parce que le parfum procure du plaisir, parfumer votre maison peut améliorer votre cadre de vie et créer une atmosphère plus agréable et confortable.</p>"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Taille du texte",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 15
    },

    {
      "type": "header",
      "content": "Caractéristiques (style)"
    },
    {
      "type": "range",
      "id": "feature_title_size",
      "label": "Taille des titres",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Taille des icônes",
      "min": 24,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 48
    },

    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Couleur de fond",
      "default": "#faf8f3"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Couleur du titre",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "feature_title_color",
      "label": "Couleur des titres de caractéristiques",
      "default": "#1a1a1a"
    },

    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espacement haut",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espacement bas",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 80
    }
  ],

  "blocks": [
    {
      "type": "feature",
      "name": "Caractéristique",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icône (PNG/SVG recommandé)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Fabrication française"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Tous nos parfums prennent vie en France, là où les rencontres humaines et les belles idées deviennent matière. C'est ici que tout commence, avec cœur et conviction."
        }
      ]
    }
  ],

  "max_blocks": 6,

  "presets": [
    {
      "name": "Image + Caractéristiques",
      "category": "Texte",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Fabrication française",
            "description": "Tous nos parfums prennent vie en France, là où les rencontres humaines et les belles idées deviennent matière. C'est ici que tout commence, avec cœur et conviction."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Artisanat",
            "description": "Rien n'est laissé au hasard. Chaque geste compte, chaque détail est soigné, comme une promesse tenue entre ceux qui créent et ceux qui accueillent nos parfums chez eux."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Créations uniques et originales",
            "description": "Nos senteurs ne suivent aucune tendance. Elles racontent une histoire, une émotion, un souvenir – nées d'élans sincères et de collaborations passionnées."
          }
        }
      ]
    }
  ]
}
{% endschema %}